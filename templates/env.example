# FanoosAI Configuration
# Copy this file to .env and fill in your credentials

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fanoosai
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800

# Redis is required outside local DEBUG mode
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=fanoosai:prompt-runs
REDIS_QUEUE_GROUP=fanoosai-workers

# JWT Settings
JWT_SECRET_KEY=your-secret-key-here
SECRET_KEY=your-secret-key-here
JWT_LIFETIME_SECONDS=3600

# Melipayamak SMS Settings
MELIPAYAMAK_USERNAME=your_username
MELIPAYAMAK_PASSWORD=your_password
MELIPAYAMAK_FROM_NUMBER=09123456789
MELIPAYAMAK_SENDER=09123456789

# Development-only fixed OTP (never enable in production)
DEBUG=false
DEV_OTP_PHONE=
DEV_OTP_CODE=

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Automatic runs and retention
RUN_TIMEZONE=Asia/Tehran
AUTOMATIC_RUN_INTERVAL_SECONDS=60
RUN_RETENTION_DAYS=365
ANALYTICS_PROMPT_LIMIT=1000
TREND_MAX_POINTS_PER_SERIES=365
