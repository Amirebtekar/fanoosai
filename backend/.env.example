# FanoosAI backend environment
# Copy this file to .env before running the app.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fanoosai
DB_ECHO=false

# JWT
JWT_SECRET_KEY=change-this-secret
SECRET_KEY=change-this-secret
JWT_LIFETIME_SECONDS=3600

# Melipayamak / SMS
MELIPAYAMAK_BASE_URL=https://api.parspack.com/api/aistudio/api/v1
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_FROM_NUMBER=
MELIPAYAMAK_SENDER=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
